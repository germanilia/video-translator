# Video Translator configuration
# Copy this file to config.env and fill in what you have.
# config.env is gitignored - secrets never reach the repo.
# Every setting is optional; the wizard tells you which line to fill when
# a choice you make needs one.

# --- Diarization (required for speaker detection) ---------------------------
# Free HuggingFace token. Also accept the model terms (one click each) at:
#   https://hf.co/pyannote/speaker-diarization-3.1
#   https://hf.co/pyannote/segmentation-3.0
HF_TOKEN=

# --- Translation (pick what you have; best available is used) ---------------
# Remote frontier model - highest quality. Leave all empty to use local Gemma.
# VT_TRANSLATOR forces a provider: pi | anthropic | openai
VT_TRANSLATOR=
ANTHROPIC_API_KEY=
VT_ANTHROPIC_MODEL=claude-sonnet-5
OPENAI_API_KEY=
VT_OPENAI_MODEL=gpt-5.4
# Parallel translation batches (remote providers only)
VT_PI_PARALLEL=6

# --- Voices (paid backend, optional) ----------------------------------------
# ElevenLabs plan with instant voice cloning; ~40K characters per 90-min movie.
ELEVENLABS_API_KEY=
# Voice slots available for character clones (plan limit minus reserved slots)
VT_11LABS_TOP_N=9
